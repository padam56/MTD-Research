# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.env
venv/
.venv/

# Generated at runtime — do not commit model weights or raw results
models/*.pkl
results/*.csv
tensorboard_logs/

# Synthetic / generated data files
data/*.csv
data/*.txt

# Plot figures (regenerated by plot_results.py)
results/figures/

# Keep the placeholder files so directories are tracked by git
!models/.gitkeep
!results/.gitkeep

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/
